# CI/CD
# ============================================

.github/workflows/
*.yml.local

# Keep these directories but ignore temp files
!logs/.gitkeep
!uploads/.gitkeep
!data/.gitkeep
!models/.gitkeep

# ============================================
# Security - Never commit
# ============================================

*.key
*.pem
*.crt
*.cert
credentials.json
secrets.json
api_keys.txt
token.txt
