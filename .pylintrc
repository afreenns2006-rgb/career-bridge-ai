[MASTER]
ignore=.git,.venv,uploads,logs,models
jobs=0

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    line-too-long,
    too-few-public-methods,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    too-many-instance-attributes,
    duplicate-code,
    broad-exception-caught,
    fixme,
    import-error,
    no-member

[FORMAT]
max-line-length=120

[REPORTS]
score=yes

[TYPECHECK]
ignored-modules=streamlit,pandas,numpy,spacy,docx,pypdf,sklearn,sentence_transformers,textblob
