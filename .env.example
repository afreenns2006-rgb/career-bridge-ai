# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================
# Application Configuration
# ============================================

# Application Name
APP_NAME=Career Bridge AI

# Environment (development, staging, production)
ENV=development

# Debug mode (True/False)
DEBUG=True

# Application port
PORT=8501

# ============================================
# Database Configuration
# ============================================

# Database path for SQLite
DATABASE_PATH=./data/career_bridge.db

# Database backup path
DATABASE_BACKUP_PATH=./data/backups/

# Enable database logging
DATABASE_LOG=False

# ============================================
# File Upload Configuration
# ============================================

# Upload directory for user files
UPLOAD_PATH=./uploads/

# Maximum file size in bytes (10MB)
MAX_FILE_SIZE=10485760

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,docx,doc,txt

# ============================================
# Logging Configuration
# ============================================

# Log file path
LOG_PATH=./logs/

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable file logging
LOG_TO_FILE=True

# Enable console logging
LOG_TO_CONSOLE=True

# ============================================
# NLP & ML Configuration
# ============================================

# spaCy language model to use
SPACY_MODEL=en_core_web_sm

# Sentence Transformer model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Enable GPU acceleration (True/False)
USE_GPU=False

# Model cache directory
MODEL_CACHE_DIR=./models/

# ============================================
# Security Configuration
# ============================================

# Secret key for session management
SECRET_KEY=your-super-secret-key-change-this

# API key for external services (if any)
API_KEY=your-api-key-here

# Enable HTTPS
ENABLE_HTTPS=False

# HTTPS certificate path (if ENABLE_HTTPS=True)
CERT_PATH=/path/to/cert.pem

# HTTPS key path (if ENABLE_HTTPS=True)
KEY_PATH=/path/to/key.pem

# ============================================
# Email Configuration
# ============================================

# Email service provider (smtp, sendgrid, aws_ses)
EMAIL_PROVIDER=smtp

# SMTP server
SMTP_SERVER=smtp.gmail.com

# SMTP port
SMTP_PORT=587

# SMTP username
SMTP_USERNAME=your-email@gmail.com

# SMTP password
SMTP_PASSWORD=your-app-password

# Email from address
EMAIL_FROM=noreply@careerbridgeai.com

# Enable email notifications
ENABLE_EMAIL=False

# ============================================
# Data Sources
# ============================================

# Scholarship data source
SCHOLARSHIP_DATA_SOURCE=./data/scholarships/

# Government schemes data source
SCHEME_DATA_SOURCE=./data/schemes/

# Opportunity data source
OPPORTUNITY_DATA_SOURCE=./data/opportunities/

# Job roles data source
JOB_DATA_SOURCE=./data/jobs/

# ============================================
# AI Configuration (NEW)
# ============================================

# AI Provider: "ollama" or "byok"
AI_PROVIDER=ollama

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# BYOK Configuration (Bring Your Own Key)
# Uncomment and set your API key if using BYOK
# BYOK_API_KEY=your_actual_api_key_here
# BYOK_PROVIDER_TYPE=openai

# ============================================
# Language Configuration (NEW)
# ============================================

# Default language: "English", "हिंदी", or "తెలుగు"
DEFAULT_LANGUAGE=English

# Enable multilingual support
ENABLE_MULTILINGUAL=True

# ============================================
# API Configuration
# ============================================

# API rate limiting (requests per minute)
RATE_LIMIT=100

# API timeout in seconds
API_TIMEOUT=30

# Enable API documentation
API_DOCS=True

# ============================================
# Cache Configuration
# ============================================

# Cache type (memory, redis, disk)
CACHE_TYPE=memory

# Cache TTL in seconds (3600 = 1 hour)
CACHE_TTL=3600

# Cache size in MB (for memory cache)
CACHE_SIZE=100

# ============================================
# External Services
# ============================================

# LinkedIn API key (future)
LINKEDIN_API_KEY=

# Google Drive API key (future)
GOOGLE_API_KEY=

# Stripe API key (future)
STRIPE_API_KEY=

# ============================================
# Analytics
# ============================================

# Enable analytics
ENABLE_ANALYTICS=True

# Google Analytics ID (if any)
GOOGLE_ANALYTICS_ID=

# Sentry error tracking (future)
SENTRY_DSN=

# ============================================
# Deployment Configuration
# ============================================

# Application URL
APP_URL=http://localhost:8501

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Workers (for production)
WORKERS=4

# ============================================
# Data Update Configuration
# ============================================

# Auto-update opportunities (True/False)
AUTO_UPDATE_OPPORTUNITIES=True

# Update interval in hours
UPDATE_INTERVAL=24

# ============================================
# Feature Flags
# ============================================

# Enable resume analysis
FEATURE_RESUME_ANALYSIS=True

# Enable career recommendations
FEATURE_CAREER_RECOMMENDATIONS=True

# Enable scholarship discovery
FEATURE_SCHOLARSHIP_DISCOVERY=True

# Enable government schemes
FEATURE_GOVT_SCHEMES=True

# Enable opportunity discovery
FEATURE_OPPORTUNITIES=True

# Enable learning roadmaps
FEATURE_LEARNING_ROADMAPS=True

# ============================================
# Development Settings (local only)
# ============================================

# Enable Streamlit reruns on save
STREAMLIT_RERUNS_ON_SAVE=True

# Streamlit theme (light/dark)
STREAMLIT_THEME=light

# ============================================
# Notes
# ============================================

# 1. Never commit .env file to Git
# 2. Use strong, unique values for SECRET_KEY
# 3. Keep API keys and passwords secure
# 4. Use environment-specific values for different deployments
# 5. Regularly rotate sensitive credentials
